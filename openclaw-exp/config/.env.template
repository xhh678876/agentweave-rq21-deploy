# AgentWeave 实验专属龙虾 —— 环境变量模板
# 拷贝为 .env 后填入真实值（.env 已经在 .gitignore，不会进版本控制）

# 主模型：DeepSeek-V4-Flash via DashScope
DASHSCOPE_API_KEY=

# 跨模型实验（EXP-5）才需要
# GLM 5.1 也走 DashScope，复用上面那个 key 即可
OPENAI_API_KEY=

# 可选：DeepSeek 官方 API（备用通道，速率更高）
DEEPSEEK_API_KEY=

# 嵌入模型版本锁（EXP-4 验证要求，跨实验必须一致）
AGENTWEAVE_EMBED_MODEL=text-embedding-v3
AGENTWEAVE_EMBED_VERSION=2024-08

# 是否启用 caffeinate 守护（macOS 防睡眠）
AGENTWEAVE_KEEP_AWAKE=1
