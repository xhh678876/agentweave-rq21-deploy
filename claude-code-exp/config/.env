# Claude Code 实验实例 - 走 DeepSeek 官方 Anthropic 兼容端点
# 文件权限 chmod 600

ANTHROPIC_BASE_URL=https://api.deepseek.com/anthropic
ANTHROPIC_AUTH_TOKEN=sk-REPLACE_ME_DEEPSEEK_KEY

# 模型映射（所有 Claude family 都路由到 deepseek-v4-flash 节省成本）
ANTHROPIC_MODEL=deepseek-v4-flash
ANTHROPIC_DEFAULT_OPUS_MODEL=deepseek-v4-flash
ANTHROPIC_DEFAULT_SONNET_MODEL=deepseek-v4-flash
ANTHROPIC_DEFAULT_HAIKU_MODEL=deepseek-v4-flash
CLAUDE_CODE_SUBAGENT_MODEL=deepseek-v4-flash

# 跑实验显式标记
AGENTWEAVE_EXP=1
AGENTWEAVE_HARNESS=claude-code

# MaaS 备用（跨模型实验用）
MAAS_API_KEY=sk-REPLACE_ME_DEEPSEEK_KEY
MAAS_BASE_URL=https://apicz.boyuerichdata.com/v1
