# Official Anthropic API key, available from https://console.anthropic.com/
ANTHROPIC_AUTH_TOKEN=your-anthropic-api-key

# If using a third-party proxy service, set the proxy URL here; leave empty for direct official API access
ANTHROPIC_BASE_URL= 

# Model names for each tier (haiku/sonnet/opus mapping)
ANTHROPIC_DEFAULT_HAIKU_MODEL=
ANTHROPIC_DEFAULT_SONNET_MODEL=
ANTHROPIC_DEFAULT_OPUS_MODEL=
