# Hermes 实验实例 - 走 DeepSeek via openrouter overlay
# Hermes 把 openrouter provider 看作"任意 OpenAI-compat endpoint"
# 通过 OPENROUTER_BASE_URL 重定向，OPENROUTER_API_KEY 提供 token

OPENROUTER_API_KEY=sk-REPLACE_ME
OPENROUTER_BASE_URL=https://api.deepseek.com/v1

# 跑实验显式标记
AGENTWEAVE_EXP=1
AGENTWEAVE_HARNESS=hermes

# MaaS 备用
MAAS_API_KEY=sk-REPLACE_ME
